---
import ProfileLayout from '../layouts/ProfileLayout.astro';
import GalleryCard from '../components/GalleryCard.jsx';

const rawEntries = await Astro.glob('../../entries/*.md');
const entries = rawEntries
  .map(e => e.frontmatter)
  .sort((a, b) => (a.order ?? 99) - (b.order ?? 99));

const base = import.meta.env.BASE_URL.replace(/\/$/, ''); // '/yuzuru-hanyu-gallery' or ''

function pub(path) {
  if (!path) return path;
  const stripped = path.replace(/^(?:assets\/|\/)/, '');
  return `${base}/${stripped}`;
}

const cards = entries.map(fm => ({
  title:         fm.title,
  slug:          fm.slug,
  href:          `${base}/${fm.slug}/`,
  year:          fm.year,
  intro:         fm.intro,
  tags:          fm.tags || [],
  cover:         pub(fm.cover),
  coverPosition: fm.coverPosition,
  previewVideo:  pub(fm.previewVideo),
  previewPoster: pub(fm.previewPoster),
}));
---

<ProfileLayout title="Yuzuru Hanyu — Visual Diary">

  <!-- ── Sidebar ── -->
  <aside id="sidebar">

    <div class="sb-name-block">
      <div class="sb-name">Yuzuru Hanyu</div>
    </div>

    <div class="sb-rule"></div>
    <div class="sb-title">Figure Skater</div>

    <div class="sb-stats">
      <div class="stat-row">
        <span class="stat-label">Olympic Gold</span>
        <span class="stat-val">2014 · 2018</span>
      </div>
      <div class="stat-row">
        <span class="stat-label">World Record</span>
        <span class="stat-val">330.43</span>
      </div>
      <div class="stat-row">
        <span class="stat-label"></span>
        <span class="stat-val"></span>
      </div>
    </div>

    <div class="sb-socials">
      <a class="social-link" href="#gallery">Gallery</a>
      <a class="social-link" href="#future">Programs</a>
      <a class="social-link" href="#future">Timeline</a>
      <a class="social-link" href="#future">Press</a>
    </div>

    <nav class="sb-nav-links">
      <a class="nav-link" href="#gallery">Gallery</a>
      <a class="nav-link" href="#future">Programs</a>
      <a class="nav-link" href="#future">Timeline</a>
      <a class="nav-link" href="#future">Press</a>
    </nav>
  </aside>

  <!-- ── Main ── -->
  <main id="main">

    <section id="gallery">
      <div class="gallery-label">— Visual Archive · {cards.length} entries</div>

      <div class="bento">
        {cards.map((card, i) => (
          <div class="bcard" data-pos={i}>
            <GalleryCard
              client:visible
              fill={true}
              title={card.title}
              year={card.year}
              slug={card.slug}
              href={card.href}
              cover={card.cover}
              coverPosition={card.coverPosition}
              intro={card.intro}
              tags={card.tags}
              previewVideo={card.previewVideo}
              previewPoster={card.previewPoster}
            />
          </div>
        ))}
      </div>
    </section>

    <section id="future">
      <div class="future-sep"></div>
      <div class="future-inner">
        <div class="future-label">— Coming Soon</div>
        <h2 class="future-heading">More to unfold</h2>
        <p class="future-hint">Timeline · Press · Contact · Essays</p>
        <div class="future-dots">
          <span></span><span></span><span></span>
        </div>
      </div>
    </section>

  </main>

</ProfileLayout>
