---
interface Props {
  title: string;
  description?: string;
}
const { title, description = 'A visual diary of Yuzuru Hanyu\'s most memorable performances.' } = Astro.props;
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <title>{title}</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;1,300;1,400&family=Inter:wght@300;400;500&display=swap" rel="stylesheet" />
  <style is:global>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --bg:        #0c0b0a;
      --bg-card:   #141312;
      --bg-pop:    #1c1a18;
      --text:      #ddd5c8;
      --text-dim:  #7d7368;
      --text-muted:#4a453f;
      --accent:    #c9a76d;
      --accent-lo: rgba(201,167,109,.14);
      --border:    rgba(255,255,255,.06);
      --radius:    12px;
      --gap:       14px;
      --serif:     'Cormorant Garamond', Georgia, serif;
      --sans:      'Inter', system-ui, sans-serif;
    }

    html { background: var(--bg); color: var(--text); font-family: var(--sans); font-size: 16px; line-height: 1.65; }
    body { min-height: 100vh; }

    a { color: inherit; text-decoration: none; }
    img { display: block; max-width: 100%; }
    button { cursor: pointer; border: none; background: none; font: inherit; color: inherit; }

    /* ── Site header ─────────────────────────── */
    .site-header {
      text-align: center;
      padding: 4.5rem 2rem 2.5rem;
      border-bottom: 1px solid var(--border);
    }
    .site-header h1 {
      font-family: var(--serif);
      font-size: clamp(2.4rem, 5vw, 4rem);
      font-weight: 300;
      letter-spacing: .12em;
      color: var(--text);
    }
    .site-subtitle {
      font-size: .8rem;
      letter-spacing: .28em;
      text-transform: uppercase;
      color: var(--text-dim);
      margin-top: .5rem;
    }

    /* ── Gallery grid (CSS columns masonry) ──── */
    .gallery-grid {
      columns: 3;
      column-gap: var(--gap);
      padding: 6rem 6rem 8rem;
    }
    @media (max-width: 900px)  { .gallery-grid { columns: 2; } }
    @media (max-width: 560px)  { .gallery-grid { columns: 1; } }

    /* ── Tag chips ───────────────────────────── */
    .tag-chip {
      display: inline-block;
      font-size: .65rem;
      font-weight: 500;
      letter-spacing: .1em;
      text-transform: uppercase;
      padding: .2em .65em;
      border-radius: 999px;
      background: var(--accent-lo);
      color: var(--accent);
      border: 1px solid rgba(201,167,109,.25);
      white-space: nowrap;
    }

    /* ── Detail page ──────────────────────────── */
    .detail-wrap {
      max-width: 1100px;
      margin: 0 auto;
      padding: 0 1.5rem 6rem;
    }

    .back-link {
      display: inline-flex;
      align-items: center;
      gap: .4em;
      font-size: .78rem;
      letter-spacing: .14em;
      text-transform: uppercase;
      color: var(--text-dim);
      padding: 1.8rem 0 2.2rem;
      transition: color .2s;
    }
    .back-link:hover { color: var(--accent); }

    /* Title block */
    .entry-title-block { margin-bottom: 2.5rem; }
    .entry-title-block h1 {
      font-family: var(--serif);
      font-size: clamp(2.2rem, 4.5vw, 3.8rem);
      font-weight: 300;
      line-height: 1.15;
      letter-spacing: .03em;
      color: var(--text);
      margin-bottom: .4rem;
    }
    .entry-meta {
      font-size: .78rem;
      letter-spacing: .16em;
      text-transform: uppercase;
      color: var(--text-dim);
      margin-bottom: 1rem;
    }
    .entry-tags { display: flex; flex-wrap: wrap; gap: .4rem; margin-bottom: 1.4rem; }
    .entry-lede {
      font-family: var(--serif);
      font-size: 1.25rem;
      font-weight: 300;
      font-style: italic;
      color: var(--text);
      line-height: 1.6;
      max-width: 680px;
      border-left: 2px solid var(--accent);
      padding-left: 1rem;
    }

    /* Lead media */
    .lead-media {
      margin: 2.5rem auto 3rem;
      max-width: 70%;
      border-radius: var(--radius);
      overflow: hidden;
    }
    .lead-media img,
    .lead-media video {
      width: 100%;
      height: auto;
      display: block;
      border-radius: var(--radius);
    }
    @media (max-width: 700px) { .lead-media { max-width: 100%; } }

    /* Article body */
    .article-body {
      max-width: 760px;
      margin: 0 auto;
    }
    .article-body h2 {
      font-family: var(--serif);
      font-size: 1.55rem;
      font-weight: 400;
      margin: 2.6rem 0 .9rem;
      color: var(--text);
    }
    .article-body h3 {
      font-family: var(--serif);
      font-size: 1.15rem;
      font-weight: 400;
      font-style: italic;
      margin: 1.8rem 0 .6rem;
      color: var(--text);
    }
    .article-body p {
      font-size: 1.025rem;
      line-height: 1.8;
      color: var(--text);
      margin-bottom: 1.1rem;
    }
    .article-body strong { color: #f0e8db; font-weight: 600; }
    .article-body em { font-style: italic; }
    .article-body blockquote {
      border-left: 2px solid var(--accent);
      padding: .8rem 1rem .8rem 1.4rem;
      margin: 1.8rem 0;
      font-family: var(--serif);
      font-size: 1.12rem;
      font-style: italic;
      color: var(--text-dim);
      background: rgba(201,167,109,.05);
      border-radius: 0 6px 6px 0;
    }
    .article-body table {
      width: 100%;
      border-collapse: collapse;
      margin: 1.5rem 0;
      font-size: .9rem;
    }
    .article-body th, .article-body td {
      padding: .55rem .9rem;
      border: 1px solid var(--border);
      text-align: left;
    }
    .article-body th {
      background: rgba(255,255,255,.04);
      color: var(--text-dim);
      font-weight: 500;
      letter-spacing: .06em;
      text-transform: uppercase;
      font-size: .78rem;
    }
    .article-body hr {
      border: none;
      border-top: 1px solid var(--border);
      margin: 2rem 0;
    }

    /* Image sections with side composition */
    .section-with-image {
      display: grid;
      gap: 2rem;
      align-items: start;
      margin: .5rem 0 2rem;
    }
    .section-with-image.layout-right {
      grid-template-columns: 1fr 38%;
    }
    .section-with-image.layout-left {
      grid-template-columns: 38% 1fr;
    }
    .section-with-image.layout-left .section-image {
      order: -1;
    }
    .section-image img {
      width: 100%;
      border-radius: var(--radius);
      object-fit: cover;
    }
    .section-prose { /* inherits article-body styles */ }

    @media (max-width: 680px) {
      .section-with-image { grid-template-columns: 1fr !important; }
      .section-with-image.layout-left .section-image { order: 0; }
    }

    /* Prose-only section */
    .prose-section { margin-bottom: 1.2rem; }

    /* Navigation widget */
    .nav-widget {
      margin-top: 5rem;
      padding-top: 2rem;
      border-top: 1px solid var(--border);
      display: grid;
      grid-template-columns: 1fr auto 1fr;
      gap: 1.5rem;
      align-items: center;
    }
    .nav-prev, .nav-next {
      display: flex;
      align-items: center;
      gap: .8rem;
      padding: .9rem;
      border-radius: var(--radius);
      border: 1px solid var(--border);
      transition: border-color .2s, background .2s;
      text-decoration: none;
    }
    .nav-prev:hover, .nav-next:hover {
      border-color: var(--accent);
      background: var(--accent-lo);
    }
    .nav-next { justify-content: flex-end; text-align: right; }
    .nav-thumb {
      width: 48px;
      height: 48px;
      border-radius: 6px;
      object-fit: cover;
      flex-shrink: 0;
    }
    .nav-label {
      font-size: .65rem;
      letter-spacing: .14em;
      text-transform: uppercase;
      color: var(--text-dim);
    }
    .nav-entry-title {
      font-family: var(--serif);
      font-size: .95rem;
      color: var(--text);
    }
    .nav-back {
      text-align: center;
      font-size: .72rem;
      letter-spacing: .18em;
      text-transform: uppercase;
      color: var(--text-dim);
      transition: color .2s;
    }
    .nav-back:hover { color: var(--accent); }

    @media (max-width: 600px) {
      .nav-widget { grid-template-columns: 1fr 1fr; }
      .nav-back { grid-column: 1/-1; order: -1; padding-bottom: .5rem; }
    }

    /* Scrollbar */
    ::-webkit-scrollbar { width: 6px; }
    ::-webkit-scrollbar-track { background: var(--bg); }
    ::-webkit-scrollbar-thumb { background: var(--text-muted); border-radius: 3px; }
  </style>
</head>
<body>
  <slot />
</body>
</html>
